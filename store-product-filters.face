                        <input id="{{specification_data.container_id}}" tabindex="-1" data-zs-filter-option-value data-zs-filter-option-value-type="{{filter.type}}" data-zs-filter-option-value-id="{{specification_data.container_id}}" data-zs-filter-option-group-id="{{filter.filter_option_group_id}}" data-zs-filter-option-value-data="{{specification_data.id}}" data-zs-filter-option-value-formatted="{{specification_data.name}}" class="theme-product-filter-check" type="checkbox" name="" />
                        <span aria-checked="false" class="theme-product-filter-custom-check" onkeydown="if(event.key === 'Enter' || event.key === ' ') toggleFilterValue(this)" role="checkbox" tabindex="0">
                          {% if page.template_vars.product_category_style == "10" %}
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="8" viewBox="0 0 10 8" fill="none">
                              <path d="M9.95133 0.243641C8.01484 1.55911 5.79831 3.50716 4.08202 6.34212C3.96412 6.5369 3.79737 6.91662 3.36909 7.63244C3.35262 7.6599 3.30609 7.72752 3.22402 7.7885C3.19368 7.81104 3.12085 7.86392 3.02375 7.88213C3.02375 7.88213 2.90065 7.90525 2.755 7.84398C1.79903 7.44142 0.407273 5.48239 0.407273 5.48239C0.155277 5.12578 0.0356364 4.94169 0.00673776 4.66773C-0.0262067 4.35505 0.0665579 3.9996 0.178396 3.57074C0.187354 3.53577 0.204115 3.4878 0.234748 3.3907C0.267981 3.28638 0.362769 2.99103 0.522289 2.62229C0.595114 2.4541 0.618233 2.4252 0.65898 2.40237C0.808097 2.31972 1.11962 2.61824 1.16384 2.66043C1.69933 3.17338 2.34319 4.53018 2.57843 5.04284C2.60559 5.08879 2.65241 5.12 2.70529 5.12664C2.78043 5.13589 2.83794 5.11075 2.86163 5.09746C2.94342 5.0518 2.97983 4.97319 2.98561 4.96221C3.08069 4.77264 4.91719 2.76736 6.39131 1.67499C7.08257 1.16262 8.18361 0.488413 9.80106 0.0144752C9.85973 -0.0126895 9.92735 -0.000552081 9.96636 0.0419289C10.0146 0.0948134 10.012 0.186422 9.95162 0.243352L9.95133 0.243641Z" fill="#603211"/>
                            </svg>
                          {% else %}
                            <svg
                              xmlns="http://www.w3.org/2000/svg" width="11" height="8" viewBox="0 0 11 8" fill="none">
                              <path d="M3.8482 7.84786L0.200195 4.19986L1.1122 3.28786L3.8482 6.02385L9.7202 0.151855L10.6322 1.06386L3.8482 7.84786Z" fill="white"/>
                            </svg>
                          {% endif %}
                        </span>
                      </div>
                      <label for="{{specification_data.container_id}}" class="theme-product-filter-text">{{ specification_data.name }}</label>
                      {% if filter.show_product_count %}
                        <div class="theme-product-filter-count">({{ specification_data.count }})</div>
                      {% endif %}
                    </div>
                  {% endif %}
                {% endfor %}
                {% if available_filter_options > filter.value_to_show_by_default %}
                  <a data-zs-filter-option-showmore-btn href="javascript:;" class="theme-product-filter-show-more">{{i18n.get("product_filters.show_more.label")}}</a>
                  <a data-zs-filter-option-showless-btn href="javascript:;" class="theme-product-filter-show-more" style="display:none;">{{i18n.get("product_filters.show_less.label")}}</a>
                {% endif %}
              {% comment %} FILTER TYPE - SPECIFICATION ENDS {% endcomment %}
            {% endif %}

            {% if filter.type == 7 %}
              {% comment %} FILTER TYPE - CUSTOM FEILD STARTS {% endcomment %}
                {% assign available_filter_options = 0 %}
                {% for custom_field_data in filter.custom_field_filter %}
                  {% if custom_field_data.count > 0 %}
                    {% assign available_filter_options = available_filter_options + 1 %}
                    <div data-zs-filter-option-value-container class="theme-product-filter-option-container" {% if available_filter_options > filter.value_to_show_by_default %}style="display:none;"{% endif %}>
                      <div class="theme-product-filter-select-option">
                        <input id="{{custom_field_data.container_id}}" tabindex="-1" data-zs-filter-option-value data-zs-filter-option-value-type="{{filter.type}}" data-zs-filter-option-value-id="{{custom_field_data.container_id}}" data-zs-filter-option-value-data="{{custom_field_data.id}}" data-zs-filter-option-value-formatted="{{custom_field_data.name}}" class="theme-product-filter-check" type="checkbox" name="" />
                        <span aria-checked="false" class="theme-product-filter-custom-check" onkeydown="if(event.key === 'Enter' || event.key === ' ') toggleFilterValue(this)" role="checkbox" tabindex="0">
                          {% if page.template_vars.product_category_style == "10" %}
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="8" viewBox="0 0 10 8" fill="none">
                              <path d="M9.95133 0.243641C8.01484 1.55911 5.79831 3.50716 4.08202 6.34212C3.96412 6.5369 3.79737 6.91662 3.36909 7.63244C3.35262 7.6599 3.30609 7.72752 3.22402 7.7885C3.19368 7.81104 3.12085 7.86392 3.02375 7.88213C3.02375 7.88213 2.90065 7.90525 2.755 7.84398C1.79903 7.44142 0.407273 5.48239 0.407273 5.48239C0.155277 5.12578 0.0356364 4.94169 0.00673776 4.66773C-0.0262067 4.35505 0.0665579 3.9996 0.178396 3.57074C0.187354 3.53577 0.204115 3.4878 0.234748 3.3907C0.267981 3.28638 0.362769 2.99103 0.522289 2.62229C0.595114 2.4541 0.618233 2.4252 0.65898 2.40237C0.808097 2.31972 1.11962 2.61824 1.16384 2.66043C1.69933 3.17338 2.34319 4.53018 2.57843 5.04284C2.60559 5.08879 2.65241 5.12 2.70529 5.12664C2.78043 5.13589 2.83794 5.11075 2.86163 5.09746C2.94342 5.0518 2.97983 4.97319 2.98561 4.96221C3.08069 4.77264 4.91719 2.76736 6.39131 1.67499C7.08257 1.16262 8.18361 0.488413 9.80106 0.0144752C9.85973 -0.0126895 9.92735 -0.000552081 9.96636 0.0419289C10.0146 0.0948134 10.012 0.186422 9.95162 0.243352L9.95133 0.243641Z" fill="#603211"/>
