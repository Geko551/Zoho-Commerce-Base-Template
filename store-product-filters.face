                        <span aria-checked="false" class="theme-product-filter-custom-check" onkeydown="if(event.key === 'Enter' || event.key === ' ') toggleFilterValue(this)" role="checkbox" tabindex="0">
                          {% if page.template_vars.product_category_style == "10" %}
