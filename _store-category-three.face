  {% comment %} CATEGORY IMAGE AND DESCRIPTION {% endcomment %}
  {% if category.products | size > 1 %}
    <div class="theme-section" {% if page.template_vars.product_category_style == '12' %}data-category-style-12{% else %}data-category-style-03{% endif %}>
      <div class="zpcontainer {% if page.template_vars.header_style == "06" && page.is_sidebar_enabled && filters.is_enabled && filters.has_filters %}theme-filter-enable-container{% endif %}">
        <div class="zprow">
          <div class="zpcol-md-6 theme-filter-icon-and-description">
            {% if filters.is_enabled && page.template_vars.product_category_style != '12' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="41" viewBox="0 0 40 41" fill="#000" data-toggle-filters onclick='toggleFilters()' aria-label="{{i18n.get("product_filters.toggle_filters")}}" role="button" tabindex='0'>
