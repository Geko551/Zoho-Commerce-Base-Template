<select style="display: none" data-zs-variants>
  {% for variant in product.variants %}
    {% assign variant_options = variant.options %}
    {% assign variant_option_identifiers = variant_options | map(attr="id") %}
    {% assign variant_images = variant.images %}
    {% assign variant_image_identifiers = variant_images | map(attr="id") %}
    <option value='{{ variant.variant_id }}' data-zs-attributes='{{ variant_option_identifiers | json }}' data-zs-images='{{ variant_image_identifiers | json }}' data-zs-hide-add-to-cart='{{variant.hide_add_to_cart}}' data-zs-show-add-to-quote='{{variant.show_add_to_quote}}'></option>
  {% endfor %}
</select>

{% for attribute in product.attributes %}
<div class="theme-product-varients-row">
    <input type="checkbox" aria-label="{{ attribute.name }}" id="attribute-details-{{ attribute.id }}" class="theme-prod-details-toggle">
    <div class="theme-product-variant" data-zs-product-variant-container="{{attribute.name}}" {% if attribute.type == 'Color' %}data-zs-product-color-variants{% endif %}>
      <div class="theme-product-variant-label" data-zs-product-variant-label>
        <label class='theme-prod-content-summary' for="attribute-details-{{ attribute.id }}">
          <span class="theme-variant-label-text">{{ attribute.name }}</span>
          <svg aria-hidden="true" class="theme-accordion-close" xmlns="http://www.w3.org/2000/svg" width="18" height="19" viewBox="0 0 18 19" fill="none">
            <path d="M6.9375 3.68823L13.1251 9.87586L6.9375 16.0632" stroke="black" stroke-width="1.54688" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </label>
      </div>

      {% if attribute.type == 'Color' %}
        <div class="theme-product-color-variations" role="radiogroup" aria-label="{{ attribute.name }}" data-zs-attribute-select data-zs-attribute-name="{{ attribute.name }}">
            {% for colorOption in attribute.options %}
            <span class="theme-product-color-image" title="{{ colorOption.value }}">
              <picture data-theme-color-label>
                <img height="60" width="60" src="{{cdn_prefix_url}}{{ product.images[0].url }}{{cdn_suffix_url}}" data-fallback="{{ product.images[0].url }}/600x600" onerror="handleFallBackForImage(this)" data-zs-attribute-option-image id='{{ colorOption.id }}'>
                <label aria-label="{{ colorOption.value }}" data-theme-color-label for='option-id-{{ colorOption.id }}' aria-checked="false" role="radio" tabindex="0" style="background:transparent;" onclick="selectcolor(this,'{{ attribute.name }}')">
                  <input type="radio" name="{{ attribute.id }}" data-zs-attribute-option id='option-id-{{ colorOption.id }}' value="{{ colorOption.id }}" data-text="{{ colorOption.value }}">
                </label>
              </picture>
            </span>
            {% endfor %}

          <div role="alert" data-error-select-flag="{{product.product_id}}" data-error-select="{{attribute.name}}{{product.product_id}}" data-variant-error="theme-data-error-{{attribute.name}}" class="theme-variant-error" style="display:none;">{{i18n.get("product.message.attribute_select",attribute.name)}}</div>
        </div>
        <label class="theme-prod-content-overlay" for="attribute-details-{{ attribute.id }}"></label>
        <aside class="theme-product-color-variations-slider" data-zs-attribute-select data-zs-attribute-name="{{ attribute.name }}">
          <div class="theme-slider-variant-header">
            <label class='theme-prod-content-summary' for="attribute-details-{{ attribute.id }}">
              <span class="theme-variant-label-text">{{ attribute.name }}</span>
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="33" height="33" viewBox="0 0 33 33" fill="none">
                <path d="M16.4198 29.5573C23.7836 29.5573 29.7531 23.5878 29.7531 16.224C29.7531 8.86016 23.7836 2.89062 16.4198 2.89062C9.05596 2.89062 3.08643 8.86016 3.08643 16.224C3.08643 23.5878 9.05596 29.5573 16.4198 29.5573Z" stroke="black" stroke-width="2"/>
                <path d="M19.7531 12.8906L13.0864 19.5573M13.0864 12.8906L19.7531 19.5573" stroke="black" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </label>
          </div>
          <div class="theme-slider-variant-body" role="radiogroup" aria-label="{{ attribute.name }}">
              {% for colorOption in attribute.options %}
                <span class="theme-product-color-image">
                  <picture data-theme-color-label>
                    <img height="60" width="60" data-zs-attribute-option-image id='{{ colorOption.id }}'>
                  </picture>
                  <span class="theme-product-color-name" data-zs-attribute-option-name>{{ colorOption.value }}</span>
                  <label data-theme-color-label for='option-id-{{ colorOption.id }}' aria-checked="false" role="radio" tabindex="0" style="background:transparent;" onclick="selectcolor(this,'{{ attribute.name }}')">
                    <input type="radio" name="{{ attribute.id }}" data-zs-attribute-option id='option-id-{{ colorOption.id }}' value="{{ colorOption.id }}" data-text="{{ colorOption.value }}">
                  </label>
                </span>
              {% endfor %}
          </div>

          <div role="alert" data-error-select-flag="{{product.product_id}}" data-error-select="{{attribute.name}}{{product.product_id}}" data-variant-error="theme-data-error-{{attribute.name}}" class="theme-variant-error" style="display:none;">{{i18n.get("product.message.attribute_select",attribute.name)}}</div>
        </aside>
      {% else %}
          <div class="theme-variant-select-container-main">
            <div class="theme-variant-select-container" role="radiogroup" aria-label="{{ attribute.name }}" data-zs-attribute-select data-zs-attribute-name="{{ attribute.name }}">
                {% for variantOption in attribute.options %}
                <span class="theme-product-variant">
                  <label data-theme-variant-label aria-checked="false" role="radio" tabindex="0" for='option-id-{{ variantOption.id }}' onclick="selectVariant(this,'{{ attribute.name }}')">
                    {{variantOption.value}}
                    <input type="radio" name="{{ attribute.id }}" data-zs-attribute-option id='option-id-{{ variantOption.id }}' value="{{ variantOption.id }}" data-text="{{ variantOption.value }}">
                  </label>
                </span>
                {% endfor %}
            </div>

            <div role="alert" data-error-select-flag="{{product.product_id}}" data-error-select="{{attribute.name}}{{product.product_id}}" data-variant-error="theme-data-error-{{attribute.name}}" class="theme-variant-error" style="display:none;">{{i18n.get("product.message.attribute_select",attribute.name)}}</div>

          </div>
          <label class="theme-prod-content-overlay" for="attribute-details-{{ attribute.id }}"></label>
          <aside class="theme-product-color-variations-slider" data-zs-attribute-select data-zs-attribute-name="{{ attribute.name }}">
            <div class="theme-slider-variant-header">
              <label class='theme-prod-content-summary' for="attribute-details-{{ attribute.id }}">
                <span class="theme-variant-label-text">{{ attribute.name }}</span>
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="33" height="33" viewBox="0 0 33 33" fill="none">
                  <path d="M16.4198 29.5573C23.7836 29.5573 29.7531 23.5878 29.7531 16.224C29.7531 8.86016 23.7836 2.89062 16.4198 2.89062C9.05596 2.89062 3.08643 8.86016 3.08643 16.224C3.08643 23.5878 9.05596 29.5573 16.4198 29.5573Z" stroke="black" stroke-width="2"/>
                  <path d="M19.7531 12.8906L13.0864 19.5573M13.0864 12.8906L19.7531 19.5573" stroke="black" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </label>
            </div>
            <div class="theme-slider-variant-body" role="radiogroup" aria-label="{{ attribute.name }}">
                {% for colorOption in attribute.options %}
                <span class="theme-product-color-image" title="{{ colorOption.value }}">
                  <span class="theme-product-color-name" data-zs-attribute-option-name>{{ colorOption.value }}</span>
                  <label data-theme-color-label for='option-id-{{ colorOption.id }}' aria-checked="false" role="radio" tabindex="0" style="background:transparent;" onclick="selectcolor(this,'{{ attribute.name }}')">
                    <input type="radio" name="{{ attribute.id }}" data-zs-attribute-option id='option-id-{{ colorOption.id }}' value="{{ colorOption.id }}" data-text="{{ colorOption.value }}">
                  </label>
                </span>
                {% endfor %}
            </div>
            <div role="alert" data-error-select-flag="{{product.product_id}}" data-error-select="{{attribute.name}}{{product.product_id}}" data-variant-error="theme-data-error-{{attribute.name}}" class="theme-variant-error" style="display:none;">{{i18n.get("product.message.attribute_select",attribute.name)}}</div>
          </aside>
      {% endif %}
    </div>
</div>
{% endfor %}
