 <a role="button"  href="javascript:;" data-zs-add-to-cart data-zs-product-variant-id="{{ product.variants[0].variant_id }}" {% if product.variants[0].hide_add_to_cart %} style="display: none;" {% endif %}>
  <span data-theme-cart-button-text="theme-cart-button-text">{{i18n.get("product.action.add_to_cart")}}</span>
  {% include '_store-product-add-to-cart-loader' %}
</a>
