<select style="display: none;position:absolute;width:0px;height:0px" data-zs-variants>
  {% for variant in product.variants %}
    {% assign variant_options = variant.options %}
    {% assign variant_option_identifiers = variant_options | map(attr="id") %}
    {% assign variant_images = variant.images %}
    {% assign variant_image_identifiers = variant_images | map(attr="id") %}
    <option value='{{ variant.variant_id }}' data-zs-attributes='{{ variant_option_identifiers | json }}' data-zs-images='{{ variant_image_identifiers | json }}' data-zs-img-url='{{cdn_prefix_url}}{{variant_images[0].url}}/400x400{{cdn_suffix_url}}'></option>
  {% endfor %}
</select>

<div class="theme-product-box-content">
  <div class="theme-product-image-area" data-zs-image-container>
      {% if product.is_out_of_stock == false && !product.is_input_custom_field_available && !product.has_variants && !(product.is_product_custom_fields_enabled || product.is_input_custom_field_available)%}
        <div class="theme-product-button-area">
          {% include '_store-product-list-add-to-cart' %}
        </div>
      {% else %}
        <div class="theme-product-button-area theme-product-button-details">
          <a data-zs-view-details href="{{product.url}}">
            <span data-theme-cart-button-text="theme-cart-button-text">{{i18n.get("product.label.view_details")}}</span>
          </a>
        </div>
      {% endif %}
    <div class="theme-product-ribbon-area" {% if product.on_sale && page.is_coupon_enabled && product.is_out_of_stock == false %} data-zs-hide-sale-on-hover  {% endif %}>
      {% if page.is_coupon_enabled && product.is_out_of_stock == false %}
        <div class="theme-prod-coupons-code-container" {% if product.on_sale %} data-on-sale {% endif %}>
          <span class="theme-prod-coupons-code" data-list-coupon-code style="display:none"></span>
       </div> 
       <div class="theme-prod-coupons-container" style = "display:none" data-zs-coupon-product-id = "{{ product.product_id }}"></div>
      {% endif %}
      {% if product.on_sale %}
        <div class="theme-product-sale-ribbon" data-zs-sale>
          <span class='theme-sale-message'>{{i18n.get("product.message.sale")}}</span>
        </div>
      {% endif %}
      {% if product.is_out_of_stock == true %}
        <div class="theme-ribbon-stock" data-zs-outofstock>{{i18n.get("product.message.out_of_stock")}}</div>
      {% endif %}
    </div>
    <span data-show-wishlist-icon style="display: none;">{{ wishlistView("list", product, page ) }}</span>
    <div class="theme-product-image-loader-dots" data-theme-product-image-loader-dots><span></span></div>
    {% include '_store-product-list-image' %}
   
  </div>
  <div class="theme-product-details-area">
    <div class="theme-product-name-rating-price">
      <div class="theme-brand-name-rating">
        {% if product.is_product_review_enabled %}
          <div class="theme-brand-name"  data-zs-brand="{{ product.brand }}">{{product.brand}}</div>
        {% endif %}
        {% if product.has_variants %}
          <div class="theme-product-list-variants">
            {% assign colorCount = 0 %}
            {% for attribute in product.attributes %}
              {% if attribute.type == 'Color' && colorCount < 1 %}
                <div class="theme-product-list-variant-option">
                  <div data-error-select-flag="{{product.product_id}}" data-error-select="{{attribute.name}}{{product.product_id}}" data-variant-error="theme-data-error-{{attribute.name}}" class="theme-variant-error" style="display:none;">{{i18n.get("product.message.attribute_select",attribute.name)}}</div>
                  <div class="theme-product-color-variant-container">
                    <fieldset role="radiogroup" aria-label="Choose {{ attribute.name }}" class="theme-product-color-variations" data-zs-attribute-select data-zs-attribute-name="{{ attribute.name }}">
                      <legend class="screen-reader-only">Choose {{ attribute.name }}</legend>
                      {% for coloroption in attribute.options %}
                        {% if loop.index < 4 %}
                          <span class="theme-product-color">
                          <label aria-label="{{ coloroption.value }}" for="option-id-{{ coloroption.id }}" data-theme-color-label style="background:{{coloroption.color_code}}" onclick="selectColorImage(this,'{{ attribute.name }}')" onkeydown="if(event.key === 'Enter' || event.key === ' ') selectcolor(this,'{{ attribute.name }}')">
                            <input id="option-id-{{ coloroption.id }}" type="radio" name="{{ attribute.id }}" data-zs-attribute-option value="{{ coloroption.id }}" data-text="{{ coloroption.value }}">
                          </label>
                          </span>
                        {% endif %}
                      {% endfor %}
                      {% if (attribute.options | size) + 1 > 4 %}
                        {% assign variants = (attribute.options | size) + 1 - 4 %}
                        <a href="{{ product.url }}" aria-label="{{i18n.get("menu.more.text")}}">
                        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="7" height="12" viewBox="0 0 7 12" fill="none">
                          <path d="M6.83594 5.95213L1.27443 11.5136L0.347513 10.5867L4.9821 5.95213L0.347513 1.31754L1.27443 0.390625L6.83594 5.95213Z" fill="#3D4236"/>
                        </svg></a>
                      {% endif %}
                    </fieldset>
                  </div>
                </div>
                {% assign colorCount = colorCount+1 %}
              {% endif %}
            {% endfor %}
            <div role="alert" data-theme-error="theme-error-message-{{product.product_id}}" style="display:none;"></div>
          </div>
        {% endif %}
      </div>
      <div class="theme-product-name" data-zs-product-name>
        <a title="{{ product.name }}" href="{{ product.url }}">{{ product.name }}</a>
      </div>
      <div class = "theme-product-price-variants">
        <div class="theme-product-price">
          {% include '_store-product-pricing-one' %}
        </div>
      </div>
    </div>
  </div>
</div>
