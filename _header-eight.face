<div {{ header_block }} data-headercontainer="zptheme-data-headercontainer" data-zs-mobile-headerstyle="{{ page.template_vars.mobile_header_style }}" class="zpheader-style-{{ page.template_vars.header_style }} {% if page.template_vars.is_mobile_header_fixed %}theme-mobile-header-fixed{% endif %} {% if page.template_vars.is_site_full_stretch %}theme-pages-full-stretch{% endif %} theme-mobile-header-style-{{ page.template_vars.mobile_header_style }} {% if  page.template_vars.header_style == "10" && !cart && !product && !collection && !wishlist %}theme-header-fixed{% endif %}">
  
  {% comment %} THEME TOPBAR STARTS HERE {% endcomment %}
    {% if page.is_contact_information_enabled || page.is_multi_currency_enabled || LANGUAGE_LIST_ENABLED || portal_position == "01" || page.is_social_icon_enabled && !page.template_vars.is_social_icon_floater_enabled || page.is_delivery_location_enabled %}
      <div class="theme-header-topbar {% if !page.is_portal_enabled %}theme-hide-res-topbar-checkout{% endif %} {% if !page.is_contact_information_enabled && !page.is_social_icon_enabled && !page.template_vars.is_social_icon_floater_enabled && !page.is_portal_enabled && page.is_multi_currency_enabled %}theme-hide-currency-checkout{% endif %} {% if page.template_vars.topbar_background == "dark" %}zpdark-header-portion{% endif %}" data-dark-part-applied="{% if page.template_vars.topbar_background == "dark" %}true{% else %}false{% endif %}" data-theme-topbar="zptheme-topbar" data-theme-show-topbar="true">
        <div class="zpcontainer">
          {% if page.is_contact_information_enabled %}
            <div data-topbarinfo-position="zptheme-topbarinfo-position">
              {% include '_contacts' %}
            </div>
          {% endif %}

          {% if page.is_social_icon_enabled && !page.template_vars.is_social_icon_floater_enabled %}
            {% include '_social-links' %}
          {% endif %}

          {% if page.template_vars.mobile_header_style == "01" && (!hide_search_in_cart_checkout || !hide_carticon_in_cart_checkout) %}
            <div class="theme-navigation-and-icons theme-search-minicart-responsive" data-search-cart-position-responsive="zptheme-search-cart-position-responsive"></div>
          {% endif %}

          {% if page.is_delivery_location_enabled && page.type != PAGE_TYPE.CHECKOUT %}
            {% include '_store-select-location' %}
          {% endif %}

          {% if portal_position == "01" %}
            <div data-theme-portal-non-responsive="zptheme-portal-non-responsive" class="theme-portal-login-header-08 {% if page.template_vars.header_style == "08" && !page.is_social_icon_enabled || page.template_vars.header_style == "08" && page.is_social_icon_enabled && page.template_vars.is_social_icon_floater_enabled %}theme-portal-space-style-08{% endif %}">
              {% include '_member-portal' %}
            </div>
          {% endif %}

          {% if page.is_multi_currency_enabled %}
            <div data-theme-currency-placeholder-non-res class="theme-currency-non-res {% if page.is_social_icon_enabled && !page.template_vars.is_social_icon_floater_enabled || page.is_portal_enabled %}theme-curency-option-left-space{% endif %}">
              {% include '_store-currency-target' %}
            </div>
          {% endif %}

          {% if LANGUAGE_LIST_ENABLED %}
            <div class="theme-lang-container-non-res {% if page.is_portal_enabled && portal_position != '02' || page.is_social_icon_enabled && !page.template_vars.is_social_icon_floater_enabled %}theme-lang-option-left-space{% endif %}" data-theme-lang-container-non-res>
              {% include '_language-list' %}
            </div>
          {% endif %}

          {% if page.template_vars.mobile_header_style == "01" && page.is_portal_enabled && portal_position == "02" && !page.is_store_enabled %}
            <div data-theme-portal-responsive="zptheme-portal-responsive" class="theme-nonresponsive-portal-position-two"></div>
          {% endif %}

        </div>
      </div>
    {% endif %}

    {{ topbar_remove_checkout_block }}
  {% comment %} THEME TOPBAR ENDS HERE {% endcomment %}

  {% comment %} THEME MAIN HEADER STARTS HERE {% endcomment %}
    <div data-megamenu-content-container class="theme-header {% if page.template_vars.header_background == "dark" %}zpdark-header-portion{% endif %}{% if !page.is_breadcrumb_enabled %} theme-breadcrumb-disabled-header{% endif %}" data-header="{% if page.template_vars.header_effect == 'header-animated' %}zptheme-data-header{% endif %}{% if page.template_vars.header_effect == 'header-transparent-animated' %}zptheme-data-header-transparent{% endif %}{% if page.template_vars.header_effect == 'none' %}none{% endif %}" data-dark-part-applied="{% if page.template_vars.header_background == "dark" %}true{% else %}false{% endif %}" data-banner-base-header="theme-banner-base-header">
      {% if (page.is_menu_enabled && (page.type != PAGE_TYPE.CHECKOUT && page.type != PAGE_TYPE.CART)) || !hide_search_in_cart_checkout || !hide_carticon_in_cart_checkout || page.is_title_enabled || page.is_logo_enabled || page.is_caption_enabled || page.is_contact_information_enabled || page.is_multi_currency_enabled || LANGUAGE_LIST_ENABLED || page.is_portal_enabled || page.is_social_icon_enabled %}
        <div class="zpcontainer theme-neobrutalism-header">
          {% if (page.template_vars.mobile_header_style != "03" || page.template_vars.mobile_header_style != "04" || page.template_vars.mobile_header_style != "05" ) && !page.is_home_page %}
            <button
              type="button"
              class="theme-responsive-goback"
              data-zs-mobile-header-responsive-goback
              aria-label="Go back"
              onclick="history.go(-1);"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path
                  fill="#3E4152"
                  fill-rule="evenodd"
                  d="M20.25 11.25H5.555l6.977-6.976a.748.748 0 000-1.056.749.749 0 00-1.056 0L3.262 11.43A.745.745 0 003 12a.745.745 0 00.262.57l8.214 8.212a.75.75 0 001.056 0 .748.748 0 000-1.056L5.555 12.75H20.25a.75.75 0 000-1.5"
                ></path>
              </svg>
            </button>
          {% endif %}

          {% if page.template_vars.mobile_header_style == "01" && ((page.is_menu_enabled && (page.type != PAGE_TYPE.CHECKOUT && page.type != PAGE_TYPE.CART)) || page.is_contact_information_enabled || page.is_multi_currency_enabled || LANGUAGE_LIST_ENABLED || page.is_social_icon_enabled) %}
            <div data-zs-responsive-menu-area class="theme-responsive-menu-area theme-navigation-and-icons zpcontainer theme-hide-burgericon-cart-mobile">
              <div class="theme-responsive-menu-container" data-zp-burger-clickable-area="mymenu1" type="button" aria-label="mymenu1">
                <span class="theme-burger-icon" data-zp-theme-burger-icon="mymenu1"></span>
              </div>
              <div class="theme-responsive-menu theme-menu-area" data-zp-responsive-container="mymenu1"></div>
            </div>
          {% endif %}

          {% include '_branding' %}
          {% if page.template_vars.mobile_header_style == "01" %}
            <div class='theme-responsive-search-and-cart-container' data-menu-and-search>
              <div data-zs-mobile-openstyle-searchbox class="theme-navigation-and-icons theme-search-minicart-responsive theme-search-openstyle-searchbox theme-search-openstyle-cart">
                <div class="theme-neobrutal-search-field-container" data-search="zptheme-search-container" onblur="toggleNeoBrutalSearch(this)">
                  <form method="get" action="{{ page.search_url }}">
                    <input type="text" {% if page.template_vars.search_style == "01" %}id="search-with-suggestion"{% endif %} name="q" placeholder="{{i18n.get("search.page.title")}}" aria-label="{{i18n.get("search.page.title")}}" maxlength="100" data-search-input="zptheme-search-input" data-zs-search-input />
                    <button type="submit" name="{{i18n.get("search.page.title")}}" aria-label="{{i18n.get("search.page.title")}}" class="theme-search-go" data-zs-search="{{page.primary_search}}">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <path d="M6.5 0C8.22391 0 9.87721 0.684819 11.0962 1.90381C12.3152 3.12279 13 4.77609 13 6.5C13 8.11 12.41 9.59 11.44 10.73L11.71 11H12.5L17.5 16L16 17.5L11 12.5V11.71L10.73 11.44C9.55037 12.4465 8.05065 12.9996 6.5 13C4.77609 13 3.12279 12.3152 1.90381 11.0962C0.684819 9.87721 0 8.22391 0 6.5C0 4.77609 0.684819 3.12279 1.90381 1.90381C3.12279 0.684819 4.77609 0 6.5 0ZM6.5 2C4 2 2 4 2 6.5C2 9 4 11 6.5 11C9 11 11 9 11 6.5C11 4 9 2 6.5 2Z" fill="black" />
                      </svg>
                    </button>
                    <div class="theme-search-loader-dots" data-theme-search-loader-dots>
                      <span></span>
                    </div>
                  </form>
                </div>
                <div class="theme-search-and-mini-cart-group">
                  {% if !hide_search_in_cart_checkout %}
                    {% comment %} SEARCH STARTS {% endcomment %}
                        <div class="theme-search theme-search-and-mini-cart-group-item" data-zs-search-container>
                          <span class="theme-search-icon" role="button" aria-label="{{i18n.get("search.page.title")}}" onclick="toggleNeoBrutalSearch(this)" data-zs-search-icon>
                            {% if page.template_vars.header_style == "08" %}
                              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                <path
                                  d="M6.5 0C8.22391 0 9.87721 0.684819 11.0962 1.90381C12.3152 3.12279 13 4.77609 13 6.5C13 8.11 12.41 9.59 11.44 10.73L11.71 11H12.5L17.5 16L16 17.5L11 12.5V11.71L10.73 11.44C9.55037 12.4465 8.05065 12.9996 6.5 13C4.77609 13 3.12279 12.3152 1.90381 11.0962C0.684819 9.87721 0 8.22391 0 6.5C0 4.77609 0.684819 3.12279 1.90381 1.90381C3.12279 0.684819 4.77609 0 6.5 0ZM6.5 2C4 2 2 4 2 6.5C2 9 4 11 6.5 11C9 11 11 9 11 6.5C11 4 9 2 6.5 2Z"
                                  fill="black" />
                              </svg>
                            {% elif page.template_vars.header_style == "10" %}
                              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M20.1229 19.5678L16.4006 15.8455M16.4006 15.8455C17.0374 15.2088 17.5424 14.4529 17.887 13.621C18.2316 12.789 18.409 11.8974 18.409 10.997C18.409 10.0965 18.2316 9.20488 17.887 8.37297C17.5424 7.54106 17.0374 6.78517 16.4006 6.14845C15.7639 5.51174 15.008 5.00667 14.1761 4.66208C13.3442 4.31749 12.4526 4.14014 11.5521 4.14014C10.6517 4.14014 9.76005 4.31749 8.92814 4.66208C8.09624 5.00667 7.34034 5.51174 6.70363 6.14845C5.41773 7.43436 4.69531 9.17842 4.69531 10.997C4.69531 12.8155 5.41773 14.5596 6.70363 15.8455C7.98953 17.1314 9.73359 17.8538 11.5521 17.8538C13.3707 17.8538 15.1147 17.1314 16.4006 15.8455Z" stroke="#150004" stroke-width="0.857091" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            {% endif %}
                          </span>
                        </div>
                        <div class="theme-search-hide-overlay" data-theme-search-overlay="theme-search-overlay" style="display:none;"></div>
                      {% comment %} SEARCH ENDS {% endcomment %}
                  {% endif %}
                  {% comment %} WISHLIST STARTS {% endcomment %}
                    {% include '_wishlist' %}
                  {% comment %} WISHLIST ENDS {% endcomment %}

                  {% if !hide_carticon_in_cart_checkout %}
                    {% comment %} MINI-CART START {% endcomment %}
                      {% include '_store-cart-count' %}
                    {% comment %} MINI-CART END {% endcomment %}
                  {% endif %}
                  {% comment %} QUOTE START {% endcomment %}
                    {% if page.is_quotes_enabled_in_storefront %}
                      {% include '_store-quotes-count' %}
                    {% endif %}
                  {% comment %} QUOTE END {% endcomment %}
                </div>
              </div>
            </div>
          {% endif %}

          {% if page.is_menu_enabled || !hide_search_in_cart_checkout || page.is_contact_information_enabled || page.is_multi_currency_enabled || LANGUAGE_LIST_ENABLED || page.is_social_icon_enabled || !hide_carticon_in_cart_checkout || page.template_vars.mobile_header_style == "01" && page.is_portal_enabled %}
            <div class="theme-navigation-and-icons" data-menu-and-search>
              {% if page.is_menu_enabled || page.is_contact_information_enabled || page.is_multi_currency_enabled || LANGUAGE_LIST_ENABLED || page.is_social_icon_enabled || page.template_vars.mobile_header_style == "01" && page.is_portal_enabled %}
                <div class="theme-menu-area" data-zp-nonresponsive-container="mymenu1">
                  <div class="theme-menu {% if template_vars.navigation_menu_icon_position == " 02"%} theme-menu-icon-top{% endif %} {% if template_vars.sub_menu_icon_position=="02" %} theme-submenu-icon-top{% endif %}" data-nav-menu-icon-width={{template_vars.size_nav_menu_icon_width | remove("px") }} data-nav-menu-icon-height={{template_vars.size_nav_menu_icon_height | remove("px") }} data-sub-menu-icon-height={{template_vars.size_sub_menu_icon_height | remove("px") }} data-sub-menu-icon-width={{template_vars.size_sub_menu_icon_width | remove("px") }} data-mega-menu-icon-width={{template_vars.size_mega_menu_icon_width | remove("px") }} data-mega-menu-icon-height={{template_vars.size_mega_menu_icon_height | remove("px") }} data-non-res-menu='zptheme-menu-non-res' data-zp-theme-menu="id: mymenu1 ;active: theme-menu-selected; maxitem:5;position: theme-sub-menu-position-change; orientation: horizontal; submenu: theme-sub-menu; moretext: {{i18n.get('menu.more.text')}}; nonresponsive-icon-el: theme-non-responsive-menu; responsive-icon-el: theme-responsive-menu; burger-close-icon: theme-close-icon; animate-open: theme-toggle-neo-animate; animate-close: theme-toggle-neo-animate-end;open-icon: theme-submenu-down-arrow; close-icon: theme-submenu-up-arrow; root-icon: theme-submenu-down-arrow; subtree-icon: theme-submenu-right-arrow;">
                    {% if page.template_vars.mobile_header_style == "01" && page.is_portal_enabled %}
                      <div class="theme-portal-style" data-theme-portal-responsive="zptheme-portal-responsive"></div>
                    {% endif %}

                    {% if page.is_menu_enabled %}
                      {{navi(menu, template_vars)}}
                    {% endif %}

                    {% if page.is_multi_currency_enabled %}
                      <div data-theme-currency-placeholder-res class="theme-currency-res"></div>
                      <div class="theme-close-mobile-currency" data-theme-currency-open-top>
                        <div class="theme-currency-open-label">
                          {{i18n.get("currency.label")}}
                        </div>
                        <div role="button" aria-label="{{i18n.get("search.page.title")}}" onclick="closeCurrencyMobile()" class="theme-currency-close-icon-container" data-theme-currency-hide-mobile></div>
                      </div>
                    {% endif %}

                    {% if LANGUAGE_LIST_ENABLED %}
                      <div class="theme-lang-container-res" data-theme-lang-container-res></div>
                    {% endif %}

                  </div>
                </div>
              {% endif %}

              {% if !hide_search_in_cart_checkout || !hide_carticon_in_cart_checkout %}
                <div class="theme-neobrutal-search-field-container" data-search="zptheme-search-container" onblur="toggleNeoBrutalSearch(this)">
                  <form method="get" action="{{ page.search_url }}">
                    <input type="text" {% if page.template_vars.search_style == "01" %}id="search-with-suggestion"{% endif %} name="q" placeholder="{{i18n.get("search.page.title")}}" aria-label="{{i18n.get("search.page.title")}}" data-search-input="zptheme-search-input" maxlength="100" data-zs-search-input />
                    <button type="submit" name="{{i18n.get("search.page.title")}}" aria-label="{{i18n.get("search.page.title")}}" class="theme-search-go" data-zs-search="{{page.primary_search}}">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <path d="M6.5 0C8.22391 0 9.87721 0.684819 11.0962 1.90381C12.3152 3.12279 13 4.77609 13 6.5C13 8.11 12.41 9.59 11.44 10.73L11.71 11H12.5L17.5 16L16 17.5L11 12.5V11.71L10.73 11.44C9.55037 12.4465 8.05065 12.9996 6.5 13C4.77609 13 3.12279 12.3152 1.90381 11.0962C0.684819 9.87721 0 8.22391 0 6.5C0 4.77609 0.684819 3.12279 1.90381 1.90381C3.12279 0.684819 4.77609 0 6.5 0ZM6.5 2C4 2 2 4 2 6.5C2 9 4 11 6.5 11C9 11 11 9 11 6.5C11 4 9 2 6.5 2Z" fill="black" />
                      </svg>
                    </button>
                    <div class="theme-search-loader-dots" data-theme-search-loader-dots>
                      <span></span>
                    </div>
                  </form>
                </div>
                <div data-search-cart-position-non-responsive="zptheme-search-cart-position-non-responsive" class="theme-search-cart-non-res">
                  <div class="theme-search-and-mini-cart-group">
                    {% if !hide_search_in_cart_checkout %}
                      {% comment %} SEARCH STARTS {% endcomment %}
                        <div class="theme-search theme-search-and-mini-cart-group-item" data-zs-search-container>
                          <span class="theme-search-icon" role="button" aria-label="{{i18n.get("search.page.title")}}" onclick="toggleNeoBrutalSearch(this)" data-zs-search-icon>
                            {% if page.template_vars.header_style == "08" %}
                              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                <path
                                  d="M6.5 0C8.22391 0 9.87721 0.684819 11.0962 1.90381C12.3152 3.12279 13 4.77609 13 6.5C13 8.11 12.41 9.59 11.44 10.73L11.71 11H12.5L17.5 16L16 17.5L11 12.5V11.71L10.73 11.44C9.55037 12.4465 8.05065 12.9996 6.5 13C4.77609 13 3.12279 12.3152 1.90381 11.0962C0.684819 9.87721 0 8.22391 0 6.5C0 4.77609 0.684819 3.12279 1.90381 1.90381C3.12279 0.684819 4.77609 0 6.5 0ZM6.5 2C4 2 2 4 2 6.5C2 9 4 11 6.5 11C9 11 11 9 11 6.5C11 4 9 2 6.5 2Z"
                                  fill="black" />
                              </svg>
                            {% elif page.template_vars.header_style == "10" %}
                              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M20.1229 19.5678L16.4006 15.8455M16.4006 15.8455C17.0374 15.2088 17.5424 14.4529 17.887 13.621C18.2316 12.789 18.409 11.8974 18.409 10.997C18.409 10.0965 18.2316 9.20488 17.887 8.37297C17.5424 7.54106 17.0374 6.78517 16.4006 6.14845C15.7639 5.51174 15.008 5.00667 14.1761 4.66208C13.3442 4.31749 12.4526 4.14014 11.5521 4.14014C10.6517 4.14014 9.76005 4.31749 8.92814 4.66208C8.09624 5.00667 7.34034 5.51174 6.70363 6.14845C5.41773 7.43436 4.69531 9.17842 4.69531 10.997C4.69531 12.8155 5.41773 14.5596 6.70363 15.8455C7.98953 17.1314 9.73359 17.8538 11.5521 17.8538C13.3707 17.8538 15.1147 17.1314 16.4006 15.8455Z" stroke="#150004" stroke-width="0.857091" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            {% endif %}
                          </span>
                        </div>
                        <div class="theme-search-hide-overlay" data-theme-search-overlay="theme-search-overlay" style="display:none;"></div>
                      {% comment %} SEARCH ENDS {% endcomment %}
                    {% endif %}
                    {% comment %} WISHLIST STARTS {% endcomment %}
                      {% include '_wishlist' %}
                    {% comment %} WISHLIST ENDS {% endcomment %}
                    {% if !hide_carticon_in_cart_checkout %}
                      {% comment %} MINI-CART START {% endcomment %}
                        {% include '_store-cart-count' %}
                      {% comment %} MINI-CART END {% endcomment %}
                    {% endif %}

                    {% comment %} PORTAL STARTS {% endcomment %}
                      {% if portal_position == "02" %}
                        <div data-theme-portal-non-responsive="zptheme-portal-non-responsive" class="theme-nonresponsive-portal-position-two">
                          {% include '_member-portal' %}
                        </div>
                      {% endif %}

                    {% comment %} PORTAL ENDS {% endcomment %}
                    {% comment %} QUOTE START {% endcomment %}
                      {% if page.is_quotes_enabled_in_storefront %}
                        {% include '_store-quotes-count' %}
                      {% endif %}
        		        {% comment %} QUOTE END {% endcomment %}
                  </div>
                </div>
              {% endif %}

            </div>
          {% endif %}

        </div>
      {% endif %}

    </div>


  {% if page.is_delivery_location_enabled && page.type != PAGE_TYPE.CHECKOUT %}
    <div class="theme-delivery-location-mobile-container">
      {% include '_store-select-location' %}
    </div>
  {% endif %}

  {% if page.template_vars.is_search_suggestion_enabled %}
    {% include '_search-suggestions' %}
  {% endif %}
</div>

{% comment %} THEME FLOATER SOCIAL ICON STARTS HERE {% endcomment %}
  {% if page.template_vars.is_social_icon_floater_enabled && page.is_social_icon_enabled %}
    <div class="zpsocialicon-floater">
      {% include "_social-links" %}
    </div>
  {% endif %}

{% comment %} THEME FLOATER SOCIAL ICON END HERE {% endcomment %}