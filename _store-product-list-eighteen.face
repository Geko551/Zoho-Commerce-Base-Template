<select style="display: none;position:absolute;width:0px;height:0px" data-zs-variants>
  {% for variant in product.variants %}
    {% assign variant_options = variant.options %}
    {% assign variant_option_identifiers = variant_options | map(attr="id") %}
    {% assign variant_images = variant.images %}
    {% assign variant_image_identifiers = variant_images | map(attr="id") %}
    <option value='{{ variant.variant_id }}' data-zs-attributes='{{ variant_option_identifiers | json }}' data-zs-images='{{ variant_image_identifiers | json }}' data-zs-img-url='{{cdn_prefix_url}}{{variant_images[0].url}}{% if !variant_images[0].is_placeholder_image %}/400x400{% endif %}{{cdn_suffix_url}}' data-zs-img-alt='{{variant_images[0].alternate_text}}'></option>
  {% endfor %}
</select>
<div class="theme-product-box-content">
  <div class="theme-product-image-area" data-zs-image-container>
    <div class="theme-product-ribbon-area">
      {% if product.on_sale %}
        <div class="theme-product-sale-ribbon" data-zs-sale>
          <span class='theme-sale-message'>
            {{i18n.get("product.message.sale")}}
          </span>
        </div>
      {% endif %}

      {% if page.is_coupon_enabled && !product.is_out_of_stock %}
        <div class = "theme-product-coupon-container">
          <span class="theme-prod-coupons-code" data-list-coupon-code style="display:none"></span>
          <div class="theme-prod-coupons-container" data-zs-coupon-product-id = "{{ product.product_id }}"></div>
        </div>
      {% endif %}
    </div>

   {% if (page.template_vars.product_list_style == '17' || page.template_vars.product_list_style == '18') && product.is_product_review_enabled %}
      <div class="theme-rating" data-zs-review-id="{{ product.review_id }}" data-zs-review-type = "average-rating"></div>
    {% endif %}

    {% include '_store-product-list-image-loader' %}
    {% include '_store-product-list-image' %}

    <div class="theme-product-wishlist">
      {{ wishlistView("list", product, page ) }}
    </div>

  </div>
  <div class="theme-product-details-area">
    {% if page.template_vars.product_list_style == '16' && product.is_product_review_enabled %}
      <div class="theme-rating" data-zs-review-id="{{ product.review_id }}" data-zs-review-type = "star-rating"></div>
    {% endif %}
    <div class="theme-name-variants">
      <div class="theme-product-name-price">
        <div class="theme-product-name-desc"> 
          <div class="theme-product-name-rating"> 
            {% if page.template_vars.is_brand_name_enabled && product.brand | size != 0 %}
              <div class="theme-brand-name"  data-zs-brand="{{ product.brand }}">{{product.brand}}  -</div>
            {% endif %}
            <div class= "theme-product-name" data-zs-product-name>
              <a title="{{ product.name }}" href="{{ product.url }}">{{ product.name }}</a>
            </div>
          </div>
          {% if page.template_vars.is_product_shortdesc_enabled && product.short_description %}
            <div class="theme-product-short-description" data-zs-product-short-description>
              {{ product.short_description }}
            </div>
          {% endif %}
        </div>

        <div class="theme-product-price">
          {% if page.template_vars.product_list_style == '17' || page.template_vars.product_list_style == '18'%}
            {% include '_store-product-pricing-one' %}
          {% else %}
            {% include '_store-product-pricing-six' %}
          {% endif %}
        </div>
      </div>

      {% if page.is_delivery_location_enabled %}
        <div class="theme-delivery-location-non-deliverable" data-zs-not-deliverable-message>
          {{i18n.get("delivery_location_availability.product.not_deliverable.message")}}
        </div>
      {% endif %}

      {% if page.template_vars.product_list_style == '18' && product.has_variants && !product.is_out_of_stock && !product.is_input_custom_field_available %}
        <div class="theme-variant-container">
          {% include "_store-product-variants-six" %}
        </div>
        <div role="alert" data-theme-error="theme-error-message-{{product.product_id}}" style="display:none;"></div>
      {% endif %}
      {% if page.template_vars.product_list_style == '17' &&  product.has_variants && !product.is_out_of_stock && !product.is_input_custom_field_available  %}
        <details class = "theme-list-variants">
          <summary class="theme-selected-variants">
            <span class="theme-variants-value" data-zs-selected-variant></span>
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6" fill="none">
              <path d="M0.893939 0.0533266L-2.18557e-07 0.947266L5 5.94727L10 0.947266L9.10606 0.0533262L5 4.15939L0.893939 0.0533266Z" fill="#808080"/>
            </svg>
          </summary>
          {% include '_store-product-variants-six' %}
        </details>
      {% endif %}
    </div>
    {% if page.template_vars.product_list_style == '17' ||  page.template_vars.product_list_style == '18' %}
      <div class="theme-product-list-addcart">
        {% if !product.is_out_of_stock && !product.is_input_custom_field_available %}
          <div class="theme-product-button-area">
            {% include '_store-product-list-add-to-cart' %}
          </div>

        {% elif (product.is_product_custom_fields_enabled && product.is_input_custom_field_available) %}
          <div class="theme-product-button-area theme-product-button-details">
            <a data-zs-view-details href="{{product.url}}" class="zpbutton zpbutton-type-primary zpbutton-style-roundcorner zpbutton-size-sm">{{i18n.get("product.label.view_details")}}</a>
          </div>

        {% elif product.is_out_of_stock %}
          <div class="theme-ribbon-stock" data-zs-outofstock>{{i18n.get("product.message.out_of_stock")}}</div>
        {% endif %}

        <div role="alert" data-theme-error="theme-error-message-{{product.product_id}}" style="display:none;"></div>
      </div>
    {% else %}
      <div class="theme-product-list-addcart">
        {% if !product.has_variants && !product.is_out_of_stock && !product.is_input_custom_field_available %}
          <div class="theme-product-button-area">
            {% include '_store-product-list-add-to-cart' %}
          </div>
        {% elif product.is_out_of_stock %}
          <div class="theme-ribbon-stock" data-zs-outofstock>{{i18n.get("product.message.out_of_stock")}}</div>
        {% else %}
          <div class="theme-product-button-area theme-product-button-details">
            <a data-zs-view-details href="{{product.url}}" class="zpbutton zpbutton-type-primary zpbutton-style-roundcorner zpbutton-size-sm">{{i18n.get("product.label.view_details")}}</a>
          </div>
        {% endif %}
        <div data-theme-error="theme-error-message-{{product.product_id}}" style="display:none;"></div>
      </div>
    {% endif %}


  </div>
</div>
