                    <span class='theme-message-text'>
                        {{i18n.get("product.message.success.delete_from_cart")}}
                    </span>
                </div>
            </div>

            <div data-toast-type='failure' data-cart-delete-failure="theme-cart-delete-failure" class="theme-cart-delete-failure-message" data-theme-message-two>
