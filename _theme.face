                      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 26 26" fill="none">
                          <rect x="1" y="1" width="24" height="24" rx="12" stroke="#E0242B" stroke-width="2"/>
                          <path d="M8.66602 8.66699L17.3327 17.3337" stroke="#E0242B" stroke-width="2" stroke-linecap="round"/>
                          <path d="M17.332 8.66699L8.66536 17.3337" stroke="#E0242B" stroke-width="2" stroke-linecap="round"/>
                      </svg>
                  </span>

                  <span data-zs-message-text></span>
