      {% if page.template_vars.store_message_style == "02" || page.template_vars.store_message_style == "06" %}
        <script>
          document.addEventListener('zp-event-add-to-cart-success', () => {
            var quickLookContainer = document.getElementById("product_quick_look");
            if (quickLookContainer) {
              closeProductQuickLook();
            }
            setTimeout(() => {
              var cartAddSuccess = document.querySelectorAll('[data-cart-add-success="theme-cart-add-success"]')[0];
              if (cartAddSuccess) {
                addClass(cartAddSuccess, 'theme-cart-success-remove');
                removeClass(cartAddSuccess, 'theme-cart-success');
              }
            }, 3000);
          })
          {% if page.template_vars.store_message_style == "02" %}
          window.addEventListener('load', positionCartSuccessMsg);
          {% endif %}
        </script>
      {% endif %}


            
  {% if page.template_vars.store_message_style == "07" %}
    <div data-cart-add-success="theme-cart-add-success" class="theme-cart-add-success-message" data-theme-message-seven>
      <div class="theme-cart-success-inner-container">
        <div class="theme-cart-message-item theme-cart-message-text">
          <span class="theme-success-icon">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="12" height="9" viewBox="0 0 12 9" fill="none">
              <g clip-path="url(#clip0_3103_9847)">
                <path d="M10.4143 1.48438L4.78208 7.11659L2.07422 4.40855" stroke="white" stroke-width="1.365" stroke-miterlimit="10"/>
              </g>
