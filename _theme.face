            </div>
      </div>
    {% endif %}

        {% if page.template_vars.store_message_style == "02" %}

            <div data-toast-type='success' data-cart-add-success="theme-cart-add-success" class="theme-cart-add-success-message" data-theme-message-two>
                <div class="theme-cart-success-inner-container">
                    <div class="theme-cart-item">
                        <div class="theme-cart-message-item theme-cart-message-prod-img">
