            </g>
            <defs>
              <clipPath id="clip0_5747_2627">
                <rect width="98.66" height="98.66" fill="white" transform="translate(0.34375 0.340088)"/>
              </clipPath>
            </defs>
        </svg>
      </div>
    {% endif %}

    {% if product.is_out_of_stock == true %}
      <div class="theme-product-out-of-stock-area" >
        <div class="theme-ribbon-stock" data-zs-outofstock>{{i18n.get("product.message.out_of_stock")}}</div>
      </div>
    {% endif %}

    <div class="theme-wishlist-icon">
      {{ wishlistView("list", product, page ) }}
    </div>
    {% include '_store-product-list-image-loader' %}
    {% if product.images[0].is_placeholder_image %}
      <a aria-hidden="true" href="{{ product.url }}" alt="{{ product.name }}" aria-label="{{ product.name }}">
        <picture>
          <img data-src="{{cdn_prefix_url}}{{ product.images[0].url }}{{cdn_suffix_url}}" width="600" height="600"
          alt="{{product.images[0].alternate_text}}" 
          style="display:none;" loading="lazy" decoding="async"
          data-fallback="{{ product.images[0].url }}"
          onerror="handleFallBackForImage(this)"/>
        </picture>
      </a>
    {% else %}
      <a aria-hidden="true" href="{{ product.url }}" alt="{{ product.name }}" aria-label="{{ product.name }}">
        <picture>
          <source srcset="{{cdn_prefix_url}}{{ product.images[0].url }}/300x300{{cdn_suffix_url}} 1x, {{cdn_prefix_url}}{{ product.images[0].url }}/600x600{{cdn_suffix_url}} 2x">
          <img width="600" height="600" data-src="{{cdn_prefix_url}}{{ product.images[0].url }}/600x600{{cdn_suffix_url}}"
          alt="{{product.images[0].alternate_text}}"
          style="display:none;" loading="lazy" decoding="async"
          data-fallback="{{ product.images[0].url }}/600x600"
          onerror="handleFallBackForImage(this)"/>
        </picture>
      </a>
    {% endif %}

  </div>

  <div class="theme-product-details-area">

    <div class='theme-product-tag-conatiner'>
      {% if product.tags | size >= 1 %}
        <div class='theme-product-tag'>
            {{ product.tags[0].name }}
        </div>
      {% endif %}
    </div>
    
    <div class="theme-product-name" data-zs-product-name>
      <a title="{{ product.name }}" href="{{ product.url }}">{{ product.name }}</a>
    </div>

    <div class = "theme-product-price-coupon">
      {% include '_store-product-pricing-six' %}
      {% if page.is_coupon_enabled && product.is_out_of_stock == false %}
        <div class="theme-prod-coupons-code-container">
          <span class="theme-prod-coupons-code" data-list-coupon-code style="display:none"></span>
        </div> 
        <div class="theme-prod-coupons-container" style = "display:none" data-zs-coupon-product-id = "{{ product.product_id }}"></div>
      {% endif %}   
    </div>

    <div class="theme-rating-cart-icon">
      {% if product.is_product_review_enabled %}
        <div class="theme-rating" data-zs-review-id = "{{ product.review_id }}" data-zs-review-type = "star-rating"></div>   
      {% endif %}

      {% if product.has_variants && product.is_out_of_stock && !product.is_input_custom_field_available %}
        <div class="theme-product-view-details">
          <a data-zs-view-details aria-label="{{i18n.get("product.label.view_details")}}" href="{{product.url}}">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M2.5 4.25C2.5 3.83579 2.83579 3.5 3.25 3.5H3.80826C4.75873 3.5 5.32782 4.13899 5.65325 4.73299C5.87016 5.12894 6.02708 5.58818 6.14982 6.00395C6.18306 6.00134 6.21674 6 6.2508 6H18.7481C19.5783 6 20.1778 6.79442 19.9502 7.5928L18.1224 14.0019C17.7856 15.1832 16.7062 15.9978 15.4779 15.9978H9.52977C8.29128 15.9978 7.2056 15.1699 6.87783 13.9756L6.11734 11.2045L4.85874 6.95578L4.8567 6.94834C4.701 6.38051 4.55487 5.85005 4.33773 5.4537C4.12686 5.0688 3.95877 5 3.80826 5H3.25C2.83579 5 2.5 4.66421 2.5 4.25ZM7.57283 10.8403L8.32434 13.5786C8.47333 14.1215 8.96682 14.4978 9.52977 14.4978H15.4779C16.0362 14.4978 16.5268 14.1275 16.68 13.5906L18.4168 7.5H6.58549L7.55906 10.7868C7.56434 10.8046 7.56892 10.8224 7.57283 10.8403ZM11 19C11 20.1046 10.1046 21 9 21C7.89543 21 7 20.1046 7 19C7 17.8954 7.89543 17 9 17C10.1046 17 11 17.8954 11 19ZM9.5 19C9.5 18.7239 9.27614 18.5 9 18.5C8.72386 18.5 8.5 18.7239 8.5 19C8.5 19.2761 8.72386 19.5 9 19.5C9.27614 19.5 9.5 19.2761 9.5 19ZM18 19C18 20.1046 17.1046 21 16 21C14.8954 21 14 20.1046 14 19C14 17.8954 14.8954 17 16 17C17.1046 17 18 17.8954 18 19ZM16.5 19C16.5 18.7239 16.2761 18.5 16 18.5C15.7239 18.5 15.5 18.7239 15.5 19C15.5 19.2761 15.7239 19.5 16 19.5C16.2761 19.5 16.5 19.2761 16.5 19Z" fill="#442200"/>
            </svg>
          </a>
        </div>
      {% else %}
        <div class="theme-product-cart-icon">
        <a role="button" aria-label="{{i18n.get("product.action.add_to_cart")}}" href="javascript:;" data-zs-add-to-cart data-zs-product-variant-id="{{ product.variants[0].variant_id }}" {% if product.variants[0].hide_add_to_cart %} style="display: none;" {% endif %}>
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M2.5 4.25C2.5 3.83579 2.83579 3.5 3.25 3.5H3.80826C4.75873 3.5 5.32782 4.13899 5.65325 4.73299C5.87016 5.12894 6.02708 5.58818 6.14982 6.00395C6.18306 6.00134 6.21674 6 6.2508 6H18.7481C19.5783 6 20.1778 6.79442 19.9502 7.5928L18.1224 14.0019C17.7856 15.1832 16.7062 15.9978 15.4779 15.9978H9.52977C8.29128 15.9978 7.2056 15.1699 6.87783 13.9756L6.11734 11.2045L4.85874 6.95578L4.8567 6.94834C4.701 6.38051 4.55487 5.85005 4.33773 5.4537C4.12686 5.0688 3.95877 5 3.80826 5H3.25C2.83579 5 2.5 4.66421 2.5 4.25ZM7.57283 10.8403L8.32434 13.5786C8.47333 14.1215 8.96682 14.4978 9.52977 14.4978H15.4779C16.0362 14.4978 16.5268 14.1275 16.68 13.5906L18.4168 7.5H6.58549L7.55906 10.7868C7.56434 10.8046 7.56892 10.8224 7.57283 10.8403ZM11 19C11 20.1046 10.1046 21 9 21C7.89543 21 7 20.1046 7 19C7 17.8954 7.89543 17 9 17C10.1046 17 11 17.8954 11 19ZM9.5 19C9.5 18.7239 9.27614 18.5 9 18.5C8.72386 18.5 8.5 18.7239 8.5 19C8.5 19.2761 8.72386 19.5 9 19.5C9.27614 19.5 9.5 19.2761 9.5 19ZM18 19C18 20.1046 17.1046 21 16 21C14.8954 21 14 20.1046 14 19C14 17.8954 14.8954 17 16 17C17.1046 17 18 17.8954 18 19ZM16.5 19C16.5 18.7239 16.2761 18.5 16 18.5C15.7239 18.5 15.5 18.7239 15.5 19C15.5 19.2761 15.7239 19.5 16 19.5C16.2761 19.5 16.5 19.2761 16.5 19Z" fill="#442200"/>
            </svg>
            <span class="theme-cart-button-loading-container" data-theme-cart-button-loading="theme-cart-button-loading" style="display:none;">
            <div class="theme-cart-button-loading-dots"><span>...</span><span></span><span></span></div>
            </span>
        </a>
        </div>
      {% endif %}
    </div>
   
  </div>
</div>
                  
