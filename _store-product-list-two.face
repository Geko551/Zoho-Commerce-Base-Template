<select style="display: none;position:absolute;width:0px;height:0px" data-zs-variants>
  {% for variant in product.variants %}
    {% assign variant_options = variant.options %}
    {% assign variant_option_identifiers = variant_options | map(attr="id") %}
    {% assign variant_images = variant.images %}
    {% assign variant_image_identifiers = variant_images | map(attr="id") %}
    <option value='{{ variant.variant_id }}' data-zs-attributes='{{ variant_option_identifiers | json }}' data-zs-images='{{ variant_image_identifiers | json }}' data-zs-img-url='{{cdn_prefix_url}}{{variant_images[0].url}}/400x400{{cdn_suffix_url}}'></option>
  {% endfor %}
</select>

<div class="theme-product-box-content">
  <div class="theme-product-image-area">
    <div class="theme-product-ribbon-area">
      {% if product.on_sale %}
        <div class="theme-product-sale-ribbon">
          <span class='theme-sale-message'>
            {{i18n.get("product.message.sale")}}
          </span>
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="43" height="60" viewBox="0 0 43 60" fill="none">
            <path d="M0.177979 0H42.3734V56.5947C42.3734 59.0989 39.7124 60.7063 37.4958 59.5412L22.8246 51.8291C21.8549 51.3194 20.6965 51.3194 19.7269 51.8291L5.05559 59.5412C2.839 60.7063 0.177979 59.0989 0.177979 56.5947V0Z" fill="url(#paint0_linear_3421_6824)"/>
            <defs>
              <linearGradient id="paint0_linear_3421_6824" x1="21.2757" y1="0" x2="21.2757" y2="62.1051" gradientUnits="userSpaceOnUse">
                <stop stop-color="#BF0000"/>
                <stop offset="0.141962" stop-color="#F60D0D"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
      {% endif %}
      {% if product.is_out_of_stock == true %}
        <div class="theme-ribbon-stock">{{i18n.get("product.message.out_of_stock")}}</div>
      {% endif %}
    </div>
    <span data-show-wishlist-icon style="display: none;">{{ wishlistView("list", product, page ) }}</span>
      {% include '_store-product-list-image' %}
    {% if product.has_variants %}
      {% include '_store-product-list-variants' %}
    {% endif %}
  </div>

  <div class="theme-product-details-area">
    <div class="theme-product-name-rating-price">
      <div class='theme-name-and-rating'>
          <div class="theme-product-name">
              <a title="{{ product.name }}" href="{{ product.url }}">{{ product.name }}</a>
          </div>
          <div class='theme-rating' style='display:none;'>
              {% if product.is_product_review_enabled %}
                <div class="theme-rating-value" data-zs-review-id = "{{ product.review_id }}" data-zs-review-type = "average-rating"></div>
              {% endif %}
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M10.9459 8.54675C10.7733 8.71408 10.6939 8.95608 10.7333 9.19341L11.3259 12.4734C11.3759 12.7514 11.2586 13.0327 11.0259 13.1934C10.7979 13.3601 10.4946 13.3801 10.2459 13.2467L7.29326 11.7067C7.19059 11.6521 7.07659 11.6227 6.95993 11.6194H6.77926C6.71659 11.6287 6.65526 11.6487 6.59926 11.6794L3.64593 13.2267C3.49993 13.3001 3.33459 13.3261 3.17259 13.3001C2.77793 13.2254 2.51459 12.8494 2.57926 12.4527L3.17259 9.17275C3.21193 8.93341 3.13259 8.69008 2.95993 8.52008L0.552594 6.18675C0.351261 5.99141 0.281261 5.69808 0.373261 5.43341C0.462594 5.16941 0.690594 4.97675 0.965927 4.93341L4.27926 4.45275C4.53126 4.42675 4.75259 4.27341 4.86593 4.04675L6.32593 1.05341C6.36059 0.986748 6.40526 0.925415 6.45926 0.873415L6.51926 0.826748C6.55059 0.792081 6.58659 0.763415 6.62659 0.740081L6.69926 0.713415L6.81259 0.666748H7.09326C7.34393 0.692748 7.56459 0.842748 7.67993 1.06675L9.15926 4.04675C9.26593 4.26475 9.47326 4.41608 9.71259 4.45275L13.0259 4.93341C13.3059 4.97341 13.5399 5.16675 13.6326 5.43341C13.7199 5.70075 13.6446 5.99408 13.4393 6.18675L10.9459 8.54675Z" fill="#00BF4C"/>
              </svg>
          </div>
      </div>
      <div class="theme-product-price">
          {% include '_store-product-pricing-three' %}
      </div>
      {% if product.attributes | size > 0 %}
        {% assign attributes = 0 %}
        {% assign attributeNames = "" %}
        {% for attr in product.attributes %}
          {% if attr.type != 'Color' %}
        	{% attributeNames = attributeNames + attr.name %}
        	{% if !loop.last %}
        		{% attributeNames = attributeNames + ', ' %}
        	{% endif %}
            {% attributes = attributes + 1 %}
          {% endif %}
        {% endfor %}
        {% if attributes > 0 %}
          <p class='theme-additional-variants'>More {{attributeNames}} available</p>
        {% endif %}
        {% if page.is_coupon_enabled && product.is_out_of_stock == false %}
          <div class="theme-prod-coupons-container" data-zs-coupon-product-id = "{{ product.product_id }}"></div>
        {% endif %}
      {% endif %}
      <div class="theme-cta-area">
        <a role="button" tabindex="0" class="theme-quick-view-icon" data-zs-quick-view onclick="javascript:viewProductQuickLook(this)" data-zs-product-url="{{ product.url }}" onkeypress="openQuickViewOnKeyPress(event, this)">
          <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="M12 9a3 3 0 0 1 3 3a3 3 0 0 1-3 3a3 3 0 0 1-3-3a3 3 0 0 1 3-3m0-4.5c5 0 9.27 3.11 11 7.5c-1.73 4.39-6 7.5-11 7.5S2.73 16.39 1 12c1.73-4.39 6-7.5 11-7.5M3.18 12a9.821 9.821 0 0 0 17.64 0a9.821 9.821 0 0 0-17.64 0"/></svg>
          <span class='theme-quickview-text'>{{i18n.get("product.label.quick_view")}}</span>
        </a>
        {{ wishlistView("list", product, page ) }}
      </div>
    </div>
  </div>
</div>
<div class='theme-product-filler'></div>