<div class="theme-quick-view-container">
	<div class="theme-overlay" role="button" aria-label="{{i18n.get("product.label.close")}}" tabindex="0" onclick="closeProductQuickLook(this)">
	</div>
	<div class="theme-product-quick-view-inner" data-zs-product-id = "{{ product.product_id }}">
		<div class="theme-product-detail-container" data-zs-product-primary-details {% if page.template_vars.product_content_style != '07' || !product.description && (page.is_specification_enabled && product.specification_group | size == 0) %} data-only-details {% endif %}>
            <div class="theme-product-detail-column theme-product-detail-image-container">
                {% include '_store-product-image-four' %}
            </div>
            <div class="theme-product-detail-column theme-product-detail-varients-container">
                <div class="theme-product-name">
                    <span data-zs-product-name>{{ product.name }}</span>
                </div>
                {% if product.is_product_review_enabled %}
                <div class='theme-ratings-wrapper'>
                    <svg xmlns="http://www.w3.org/2000/svg" width="19" height="20" viewBox="0 0 19 20" fill="none">
                        <mask id="mask0_1433_62" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="2" y="2" width="15" height="15">
                            <path d="M8.56901 2.96864C8.80196 2.25171 9.81622 2.25171 10.0492 2.96864L11.2244 6.58564C11.3286 6.90626 11.6274 7.12334 11.9645 7.12334H15.7676C16.5215 7.12334 16.8349 8.08796 16.225 8.53105L13.1482 10.7665C12.8755 10.9646 12.7613 11.3159 12.8655 11.6365L14.0408 15.2535C14.2737 15.9704 13.4531 16.5666 12.8433 16.1235L9.76648 13.8881C9.49375 13.6899 9.12443 13.6899 8.8517 13.8881L5.77489 16.1235C5.16503 16.5666 4.34448 15.9704 4.57742 15.2535L5.75266 11.6365C5.85683 11.3159 5.74271 10.9646 5.46997 10.7665L2.39316 8.53105C1.78331 8.08796 2.09673 7.12334 2.85055 7.12334H6.6537C6.99082 7.12334 7.2896 6.90627 7.39378 6.58565L8.56901 2.96864Z" fill="#D9D9D9"/>
                        </mask>
                        <g mask="url(#mask0_1433_62)">
                            <rect x="-7.49658" y="-14.3027" width="33.6118" height="33.6118" fill="#EEB41D"/>
                        </g>
                    </svg>

                    <div class="theme-rating-review-container">
                        <div class="theme-rating-review" data-comments-summary = "average-rating-review-count-write-review"></div>
                    </div>
                </div>
                {% endif %}
                {% if !product.is_returnable %}
                <div class="theme-prod-non-returnable" data-zs-product-non-returnable>
                    {{i18n.get("product.label.non_returnable")}}
                </div>
                {% endif %}

                {% include '_store-product-pricing-five' %}

                {% if product.tags | size != 0 %}
                <div class="theme-product-varients-row" data-zs-tags-container>
                    <div class="theme-tag-sku">
                        <ul class="theme-tag-list-container">
                            {% for tag in product.tags %}
                            <li class="theme-hover-element">
                                <a tabindex="0" aria-label="{{ tag.name }}" class="theme-product-tag-url" href="{{ tag.url }}">
                                    <span class="theme-product-tag-name">{{ tag.name }}</span>
                                </a>
                            </li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
                {% endif %}
                
                {% if page.is_coupon_enabled && product.is_out_of_stock == false %}
                <div class="theme-product-varients-row" data-coupons-container style="width: 100%;">
                    <div class="theme-prod-coupons-outtercontainer" data-zs-app="product_coupons" data-zs-coupons-list></div>
                </div>
                {% endif %}
                
                {% if product.is_out_of_stock == true || product.variants.is_out_of_stock == true %}
                <div class="theme-product-stock-availability-details" data-zs-product-outofstock>
                    {% if product.has_variants %}
                    {% for variant in product.variants %}
                    <span class="theme-prod-stock-details" data-variant-id-stock="{{ variant.variant_id }}" data-stock-avail="{{variant.is_out_of_stock}}" style="display:none;">
                        {{i18n.get("product.message.out_of_stock")}}
                    </span>
                    {% endfor %}
                    {% else %}
                    {% if product.is_out_of_stock == true %}
                    <span class="theme-prod-stock-details {% if product.is_out_of_stock == true %}theme-out-of-stock {% else %} theme-stock-background-color{% endif %}">
                        {{i18n.get("product.message.out_of_stock")}}
                    </span>
                    {% endif %}
                    {% endif %}
                </div>
                {% endif %}
                
                {% if product.short_description %}
                <div class="theme-product-varients-row" data-zs-description-container>
                    <div class="theme-product-variant-label theme-row-labels" data-zs-description-label>
                        <span>{{i18n.get("product.label.tags")}}</span>
                        <span>:</span>
                    </div>
                    <div class="theme-product-short-description" data-zs-product-short-description>
                        {{ product.short_description }}
                    </div>
                </div>
                {% endif %}
                
                {% if product.has_variants %}
                <div class="theme-product-varients-area">
                    {% include "_store-product-variants-four" %}
                </div>
                {% endif %}

                {% include "_store-product-custom-field-two" %}

                {% if page.is_delivery_location_enabled %}
                <div class="theme-product-details-delivery-location-row">
                    <p class="theme-product-details-delivery-location-input-label">{{i18n.get("delivery_location_availability.label.delivery")}}</p>
                    <input class="theme-product-details-delivery-location-postalcode" type="text" maxlength="6" id="delivery_location_postalcode" data-zs-delivery-location-postalcode="" placeholder="{{i18n.get("delivery_location_availability.label.postal_code.enter")}}">
                    <p data-zs-delivery-availability-product-details-error-message class="theme-delivery-location-error" style="display:none;">{{i18n.get("delivery_location_availability.label.error.invalid.postal_code")}}</p>
                    <div class="theme-product-delivery-location-deliverable-details">
                        {% for variant in product.variants %}
                        <span class="theme-product-details-delivery-location-message" data-zs-delivery-availability-variant-id="{{ variant.variant_id }}" data-zs-delivery-availability data-zs-delivery-stock-availability-status style="display:none;">
                        </span>
                        {% endfor %}
                        <a id="delivery-availability-apply-postalcode" data-zs-product-details-delivery-availablity href="javascript:;">{{i18n.get("delivery_location_availability.label.delivery.location.select")}}</a>
                    </div>
                </div>
                {% endif %}

                {% include "_store-product-quantity-add-cart-three" %}
            </div>
        </div>
	</div>
</div>
