<div data-theme-portal="zptheme-portal" aria-label="{{i18n.get('common.member_portal')}}" tabindex='0' class="theme-portal-login {% if ((page.template_vars.header_style == "04" || page.template_vars.header_style == "08") ||  page.template_vars.header_style == "09") && page.is_social_icon_enabled && !page.template_vars.is_social_icon_floater_enabled || page.template_vars.header_style == "05" && page.is_social_icon_enabled && !page.template_vars.is_social_icon_floater_enabled || page.template_vars.header_style == "05" && page.is_contact_information_enabled %}theme-portal-space{% endif %} {% if portal_position == "02" %}theme-portal-icon-enabled{% endif %}">
  {% if portal_position == "02" %}
    {% if page.template_vars.store_template_no == "13" %}
      <svg class="theme-portal-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="17" viewBox="0 0 16 17" fill="none">
