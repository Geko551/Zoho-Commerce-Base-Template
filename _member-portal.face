      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="11" height="15" viewBox="0 0 11 15" fill="none">
        <circle cx="5.44426" cy="3.10314" r="2.32576" stroke="#4A260C" stroke-width="0.828196"/>
